{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go-Actions/v8.3/.Modules/settings.schema.json",
  "type": "AppSource App",
  "templateUrl": "https://github.com/microsoft/AL-Go-AppSource@main",
  "enableAppSourceCop": true,
  "installOnlyReferencedApps": true,
  "trustMicrosoftNuGetFeeds": true,
  "trustedNuGetFeeds": [
    {
      "url": "https://nuget.pkg.github.com/gitspacecadet/index.json",
      "authTokenSecret": "GhTokenWorkflow",
      "patterns": [
        "K3.*"
      ]
    }
  ],
  "DeliverToGitHubPackages": {
    "ContinuousDelivery": true,
    "Branches": ["main", "release/*"]
  },
  "CICDPushBranches": ["main", "release/*", "feature/*"],
  "CICDPullRequestBranches": ["main"],
  "conditionalSettings": [
    {
      "branches": ["main"],
      "settings": {
        "nuGetFeedSelectMode": "LatestMatching"
      }
    },
    {
      "branches": ["release/*"],
      "settings": {
        "nuGetFeedSelectMode": "EarliestMatching"
      }
    },
    {
      "workflows": [" Test Next Minor"],
      "settings": {
        "workflowSchedule": {
          "cron": "39 21 * * *"
        }
      }
    },
    {
      "workflows": [" Test Next Major"],
      "settings": {
        "workflowSchedule": {
          "cron": "44 21 * * *"
        }
      }
    },
    {
      "workflows": [" Update AL-Go System Files"],
      "settings": {
        "workflowSchedule": {
          "cron": "49 21 * * *"
        }
      }
    }
  ],
  "enableCodeCop": true,
  "enableUICop": true,
  "skipUpgrade": false,
  "doNotBuildTests": true,
  "doNotRunBcptTests": true,
  "doNotRunTests": true,
  "useCompilerFolder": false,
  "doNotPublishApps": false,
  "doNotSignApps": true,
  "runs-on": "ubuntu-latest",
  "githubRunner": "self-hosted",
  "incrementalBuilds": {
    "onPush": false,
    "onPull_Request": false,
    "onSchedule": false,
    "retentionDays": 30,
    "mode": "modifiedApps"
  },
  "versioningStrategy": 3
}
